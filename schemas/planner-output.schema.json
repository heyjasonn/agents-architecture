{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/planner-output.schema.json",
  "title": "PlannerArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "agent", "version", "output"],
  "properties": {
    "task_id": { "type": "string" },
    "agent": { "const": "planner" },
    "version": { "type": "integer", "minimum": 1 },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_spec"],
      "properties": {
        "execution_spec": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "overview",
            "scope",
            "functional_requirements",
            "business_rules",
            "edge_cases",
            "acceptance_criteria",
            "test_scenarios",
            "non_functional_requirements",
            "rollout_and_rollback",
            "open_questions",
            "implementation_plan"
          ],
          "properties": {
            "overview": { "type": "string" },
            "scope": { "type": "object", "additionalProperties": true },
            "functional_requirements": { "type": "array", "items": { "type": "string" } },
            "business_rules": { "type": "array", "items": { "type": "string" } },
            "edge_cases": { "type": "array", "items": { "type": "string" } },
            "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
            "test_scenarios": { "type": "array", "items": { "type": "string" } },
            "non_functional_requirements": { "type": "object", "additionalProperties": true },
            "rollout_and_rollback": { "type": "array", "items": { "type": "string" } },
            "open_questions": { "type": "array", "items": { "type": "string" } },
            "implementation_plan": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

