{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tester-output.schema.json",
  "title": "TesterArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "agent", "version", "output"],
  "properties": {
    "task_id": { "type": "string" },
    "agent": { "const": "tester" },
    "version": { "type": "integer", "minimum": 1 },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tests_added",
        "covered_scenarios",
        "uncovered_scenarios",
        "observed_risks",
        "test_matrix",
        "regression_risk_level"
      ],
      "properties": {
        "tests_added": {
          "type": "array",
          "items": { "type": "string" }
        },
        "covered_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncovered_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observed_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["description"],
            "properties": {
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        },
        "test_matrix": {
          "type": "object",
          "additionalProperties": true
        },
        "regression_risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

